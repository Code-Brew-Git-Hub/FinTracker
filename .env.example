# Скопируйте этот файл в .env и при необходимости измените значения.
# Команда в PowerShell: Copy-Item .env.example .env
# Файл .env создаётся автоматически при первом запуске start.bat

# --- База данных (хранится локально на вашем ПК) ---
DB_NAME=FinTrackerDb
DB_USER=postgres
DB_PASSWORD=fintracker

# --- Порты (адреса в браузере) ---
# Сайт откроется по http://localhost:8080
API_PORT=5009
FRONTEND_PORT=8082

# --- Публичные URL (для деплоя за reverse proxy / в интернет) ---
# Полный адрес API, который использует фронтенд в браузере.
# Локально: http://localhost:5009/api
# Продакшен: https://api.example.com/api или https://example.com/api
API_URL=http://192.168.0.20:5009/api

# Адрес сайта (для CORS на API). Должен совпадать с URL в браузере.
# Локально: http://localhost:8082
# Продакшен: https://fintracker.example.com
FRONTEND_URL=http://192.168.0.20:8082

# --- Версия программы (для готовых образов с GitHub) ---
# Укажите номер релиза, который вы скачали, например v0.0.3
# Список версий: https://github.com/Code-Brew-Git-Hub/FinTracker/releases
GHCR_OWNER=code-brew-git-hub
FINTRACKER_VERSION=latest

# --- GitLab CI/CD (Settings → CI/CD → Variables) ---
# Для деплоя через GitLab задайте там же:
#   API_URL, FRONTEND_URL, DB_PASSWORD
# Локально эти значения берутся из этого .env файла.
