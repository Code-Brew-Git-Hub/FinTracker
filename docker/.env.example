# Скопируйте в корень проекта: Copy-Item docker\.env.example .env
# Файл .env создаётся автоматически при первом запуске start.bat

# --- Режим запуска ---
# local  — ваш ПК (start.bat), сайт на http://localhost:8080
# server — Linux-сервер с доменом и HTTPS (см. docs/deployment-server.md)
DEPLOY_MODE=local

# --- База данных ---
DB_NAME=FinTrackerDb
DB_USER=postgres
DB_PASSWORD=fintracker

# --- Порты (только для DEPLOY_MODE=local) ---
# Сайт откроется по http://localhost:8080
API_PORT=5009
FRONTEND_PORT=8080

# --- Версия программы (для готовых образов с GitHub) ---
# Укажите номер релиза, который вы скачали, например v0.0.3
# Список версий: https://github.com/Code-Brew-Git-Hub/FinTracker/releases
GHCR_OWNER=code-brew-git-hub
FINTRACKER_VERSION=latest

# --- Сервер (только для DEPLOY_MODE=server) ---
# HTTPS через Nginx Proxy Manager (npm) → http://docker-host:8082
DOMAIN=fintracker.trydov1k.online
PUBLIC_URL=https://fintracker.trydov1k.online
FINTRACKER_HOST_PORT=8082

# На сервере .env создаётся автоматически из GitLab CI/CD Variables (см. docs/deployment-server.md)
