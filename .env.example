# Copy to .env and adjust if needed: cp .env.example .env

DB_NAME=FinTrackerDb
DB_USER=postgres
DB_PASSWORD=fintracker

API_PORT=5009
FRONTEND_PORT=8080

# Готовые образы (docker-compose.images.yml). Организация GitHub в нижнем регистре.
GHCR_OWNER=code-brew-git-hub
# latest — последняя сборка с main; v1.0.0 — тег релиза (см. GitHub Releases)
FINTRACKER_VERSION=latest
